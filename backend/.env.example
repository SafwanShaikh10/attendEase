# AttendEase Backend Environment Configuration
# Copy this file to .env and replace the values with your actual configuration.

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Database (Prisma)
# Replace 'username', 'password', 'localhost', '5432', and 'attendease_db' with your Postgres details
DATABASE_URL="postgresql://username:password@localhost:5432/attendease_db?schema=public"

# Security
# Generate a strong random string for JWT_SECRET (e.g., using `openssl rand -base64 32`)
JWT_SECRET="your_super_secret_jwt_key_here"

# Email Configuration (Nodemailer)
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password_here"

# OAuth Configuration (Google Auth)
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# GitHub Token (For AI Agent Access)
GITHUB_TOKEN="your_github_pat_here"
